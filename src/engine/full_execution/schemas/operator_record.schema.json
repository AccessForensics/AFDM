{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Appendix A10 \u2014 OperatorRecord Schema (Locked)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "operator_id",
    "matter_id",
    "assigned_timestamp_local",
    "assigned_timestamp_epoch_ms",
    "independence_attestation"
  ],
  "properties": {
    "operator_id": {
      "type": "string",
      "minLength": 1
    },
    "matter_id": {
      "type": "string",
      "minLength": 1
    },
    "assigned_timestamp_local": {
      "type": "string",
      "minLength": 19
    },
    "assigned_timestamp_epoch_ms": {
      "type": "integer",
      "minimum": 0
    },
    "independence_attestation": {
      "type": "boolean",
      "const": true
    }
  }
}